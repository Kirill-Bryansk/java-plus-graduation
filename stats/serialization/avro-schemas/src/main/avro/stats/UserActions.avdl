@namespace("ru.practicum.ewm.stats.avro")
protocol UserActionProtocol {

	enum ActionTypeAvro {
		VIEW,
		REGISTER,
		LIKE
	}

	record UserActionAvro {
		long userId;                // пользователь
		long eventId;               // мероприятие
		ActionTypeAvro actionType;  // Тип действия
		timestamp_ms timestamp;    // Временная метка действия
	}
}
